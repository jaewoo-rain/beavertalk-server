# ──────────────────────────────────────────────
# 환경변수 / 비밀값
# ──────────────────────────────────────────────
.env
.env.*
!.env.example          # 템플릿은 커밋(값은 비워둘 것)

# ──────────────────────────────────────────────
# Python
# ──────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
*.egg

# 가상환경
.venv/
venv/
env/
ENV/

# 테스트 / 린트 / 타입 캐시
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.tox/
coverage.xml

# ──────────────────────────────────────────────
# 데이터베이스 (로컬)
# ──────────────────────────────────────────────
*.sqlite3
*.sqlite
*.db

# ──────────────────────────────────────────────
# 로그 / 임시
# ──────────────────────────────────────────────
*.log
hs_err_pid*.log        # JVM 크래시 덤프
*.tmp
*.bak

# ──────────────────────────────────────────────
# 프론트엔드 (front/ — Vite + Node)
# ──────────────────────────────────────────────
node_modules/
front/node_modules/
front/dist/
front/.devserver.log
front/.qa/
*.local

# ──────────────────────────────────────────────
# IDE / 에디터
# ──────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ──────────────────────────────────────────────
# OS
# ──────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

